# ============================================================================
# EVO DIGITAL — Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# The app runs in DEMO MODE when Firebase credentials are not configured.
# ============================================================================

# ─── Site Configuration ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Admin Authentication ────────────────────────────────────────────────────
# Password to access the /admin panel (UI login)
NEXT_PUBLIC_ADMIN_PASSWORD=change_me_strong_password

# Secret key to protect admin API routes (used in Authorization header)
ADMIN_SECRET_KEY=generate_a_random_64_char_string_here

# ─── Download Security ───────────────────────────────────────────────────────
# Secret used to HMAC-sign download links (keep this private!)
DOWNLOAD_TOKEN_SECRET=generate_another_random_secret_here

# ─── Firebase Client SDK ─────────────────────────────────────────────────────
# Get these from Firebase Console → Project Settings → General → Your Apps
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef123456
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Firebase Admin SDK ──────────────────────────────────────────────────────
# Get these from Firebase Console → Project Settings → Service Accounts
# → Generate New Private Key
FIREBASE_ADMIN_PROJECT_ID=your_project_id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"

# ─── Email (SMTP) ────────────────────────────────────────────────────────────
# For Gmail: use smtp.gmail.com / 587 / your Gmail / App Password
# For Resend: use smtp.resend.com / 465 / resend / your_api_key
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="Evo Digital" <noreply@evodigital.dz>
ADMIN_EMAIL=admin@evodigital.dz

# ─── Webhook — Automation (n8n / Zapier / Make) ──────────────────────────────
# When an order is created, a POST request is sent to these URLs
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=

# Secondary webhook for delivery automation
DELIVERY_WEBHOOK_URL=
DELIVERY_WEBHOOK_SECRET=

# ─── Analytics & Marketing ───────────────────────────────────────────────────
# Google Analytics 4 — Measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# Facebook Pixel ID (e.g. 1234567890123456)
NEXT_PUBLIC_FACEBOOK_PIXEL_ID=

# Google Tag Manager ID (e.g. GTM-XXXXXXX)
NEXT_PUBLIC_GTM_ID=
